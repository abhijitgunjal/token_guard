# =============================================================================
# token_guard — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo

# -----------------------------------------------------------------------------
# Distribution / packaging
# -----------------------------------------------------------------------------
dist/
build/
*.egg-info/
*.egg
MANIFEST
.eggs/

# -----------------------------------------------------------------------------
# Virtual environments
# -----------------------------------------------------------------------------
.venv/
venv/
env/
ENV/
.env

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
.pytest_cache/
.coverage
coverage.xml
htmlcov/
*.log

# -----------------------------------------------------------------------------
# IDEs
# -----------------------------------------------------------------------------

# VSCode
.vscode/

# PyCharm / JetBrains
.idea/

# -----------------------------------------------------------------------------
# OS
# -----------------------------------------------------------------------------

# macOS
.DS_Store

# Windows
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# token_guard specific
# -----------------------------------------------------------------------------

# SQLite databases created by SQLiteStorage
*.db
*.sqlite
*.sqlite3

# Any local .env files with API keys (GROQ_API_KEY, AWS credentials etc.)
.env
.env.*
!.env.example
